---
import Layout from '../../layouts/Layout.astro';
import newsData from '../../../public/news.json';
import guidesData from '../../../public/guides.json';

export async function getStaticPaths() {
  return [...guidesData, ...newsData].map(article => ({
    params: { id: article.id },
    props: { article }
  }));
}

const { article } = Astro.props;

// Dynamic SEO setup for each article page
const articleDescription = article.summary.substring(0, 160);
const articleKeywords = `${article.category.toLowerCase()}, pulso finanzas, noticias de mercado, finanzas personales, ${article.sourceName.toLowerCase()}, ${article.title.toLowerCase().split(' ').slice(0, 4).join(', ')}`;

const newsSchema = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": article.title,
  "description": article.summary,
  "datePublished": "2026-07-06T00:00:00Z",
  "author": {
    "@type": "Person",
    "name": article.author
  },
  "publisher": {
    "@type": "Organization",
    "name": "Pulso Finanzas",
    "logo": {
      "@type": "ImageObject",
      "url": "https://pulso-finanzas.com/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://pulso-finanzas.com/noticias/${article.id}`
  }
};
---

<Layout 
  title={article.title} 
  description={articleDescription} 
  keywords={articleKeywords} 
  articleSchema={newsSchema} 
  showSidebar={true}
>
  
  <article class="reader-view">
    <a href="/" class="reader-back-btn">
      <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
      Volver a las Noticias
    </a>
    
    <header class="article-header">
      <span class="article-meta">{article.category} | Publicado el {article.date} (<span class="news-time-ago" data-timestamp={article.timestamp}>{article.date}</span>)</span>
      <h1 class="article-title">{article.title}</h1>
      <p style="font-family: var(--font-sans); font-size: 0.8rem; color: var(--text-muted); margin-top: 10px;">Adaptación por: <strong>{article.author}</strong> (con información de <strong>{article.sourceName}</strong>)</p>
    </header>


    
    <div class="article-body">
      <!-- Renders HTML safely from JSON -->
      <div set:html={article.body} />

      <!-- ORIGINAL EDITORIAL COMMENTARY (Safe, Legal & High Utility CTA) -->
      <div style="background-color: var(--bg-secondary); border: 2px solid var(--color-red-gestion); padding: 25px; margin: 30px 0; border-left-width: 8px;">
        <h4 style="font-family: var(--font-sans); font-size: 0.85rem; font-weight: 800; color: var(--color-red-gestion); text-transform: uppercase; margin-bottom: 10px; letter-spacing: 1px;">Análisis & Utilidad Práctica:</h4>
        <p style="font-family: var(--font-body); font-size: 0.95rem; color: var(--text-main); line-height: 1.6; margin-bottom: 15px;">
          {article.editorialComment}
        </p>
        <div style="margin-top: 15px;">
          <a href={`/herramientas#${article.relatedTool}`} class="btn btn-primary" style="display: inline-flex; width: auto; font-size: 0.8rem; padding: 10px 20px;">
            Simular en nuestras Herramientas de Cálculo →
          </a>
        </div>
      </div>

      <div style="font-family: var(--font-sans); font-size: 0.78rem; color: var(--text-muted); border-top: 1px solid var(--border-color); padding-top: 15px; margin-top: 25px; display: flex; flex-direction: column; gap: 8px; line-height: 1.4;">
        <div>
          <strong>Nota Editorial de Cocuraduría:</strong> En Pulso Finanzas realizamos un trabajo de traducción, síntesis y adaptación de reportes económicos de medios de comunicación internacionales de alta autoridad. Nuestro equipo editorial añade análisis prácticos propios de utilidad directa y los vincula con herramientas de cálculo interactivas para que el lector de habla hispana pueda comprender e instrumentar el impacto de la noticia en su economía personal.
        </div>
        <div>
          <span>Fuente de información original: <strong>{article.sourceName}</strong></span>
          {article.sourceUrl !== '/' && (
            <a href={article.sourceUrl} target="_blank" rel="noopener noreferrer" style="color: var(--color-red-gestion); text-decoration: underline; margin-left: 5px;">
              Ver nota original completa →
            </a>
          )}
        </div>
      </div>
    </div>


    <a href="/" class="reader-back-btn" style="margin-top: 30px;">
      <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
      Volver a las Noticias
    </a>
  </article>

</Layout>
